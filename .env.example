# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=edmaj

# JWT – replace with a strong random secret
JWT_SECRET=change-me-to-a-strong-random-secret

# Environment: development | production
NODE_ENV=development

# Set to "true" to auto-sync schema (dev only — use migrations in production)
TYPEORM_SYNC=false

# Server port
PORT=3000
